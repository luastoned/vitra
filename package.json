{
  "name": "vitra",
  "description": "A quick way to get started with React, Chakra UI using Vite, TypeScript",
  "version": "0.0.0",
  "repository": "git@github.com:luastoned/vitra.git",
  "author": "Gregor Steiner <spacegregor@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:eslint": "eslint .",
    "preview": "vite preview",
    "snippets": "npx @chakra-ui/cli snippet add --outdir src/shared/ui/chakra",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.12"
  }
}
