{
  "name": "vitra",
  "description": "A quick way to get started with React, Chakra UI using Vite, TypeScript",
  "version": "0.0.0",
  "repository": "git@github.com:luastoned/vitra.git",
  "author": "Gregor Steiner <spacegregor@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "snippets": "npx @chakra-ui/cli snippet add --outdir src/components/chakra",
    "check": "biome check src",
    "format": "biome format src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.32.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.158.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "unplugin-fonts": "^1.4.0",
    "vite": "npm:rolldown-vite@7.2.5",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "resolutions": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
